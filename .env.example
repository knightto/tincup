# Standalone Tin Cup app (root runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
PORT=3000
AUTO_SEED_ON_STARTUP=true

# Optional: allow verify:seed to compare against golden totals when
# hole-by-hole scores are not present in seed/tincup-2022-scores.json.
VERIFY_ALLOW_GOLDEN_FALLBACK=false
