# Shared/live Tin Cup integration pieces
# This is the subset of env vars that matter for Tin Cup while it still runs
# inside the Tee Time BRS Render deployment.

# Host app context
PORT=5000
SITE_URL="https://tee-time-brs.onrender.com/"
LOCAL_TZ="America/New_York"

# Mongo connections used by Tin Cup trip data / seed scripts
MONGO_URI=""
MONGO_DB=""
MONGO_URI_SECONDARY=""
MONGO_DB_SECONDARY=""

# Admin codes used by trip/Tin Cup routes
SITE_ADMIN_WRITE_CODE="123"
ADMIN_DELETE_CODE=""
ADMIN_DESTRUCTIVE_CODE=""
ADMIN_DESTRUCTIVE_CONFIRM_CODE=""

# Testing / browser automation for Tin Cup pages
E2E_TEST_MODE=0
E2E_PORT=""
E2E_BROWSER_BIN=""
E2E_TIN_CUP_BROWSER_DEBUG_PORT=9224

# Optional local bypass when running isolated snapshot tests
SKIP_MONGO_CONNECT=0
